# Copy this file to .env and fill in your own values.
# .env is git-ignored — never commit your real credentials.

# Your Kicktipp login (email and password).
KICKTIPP_EMAIL=you@example.com
KICKTIPP_PASSWORD=your-password-here

# The community slug from your Kicktipp URL, e.g. for
# https://www.kicktipp.de/my-community/ the value is "my-community".
KICKTIPP_COMMUNITY=your-community-slug

# Optional: override the claude CLI binary path (default: "claude" on PATH).
# Only needed for the "llm" tipping strategy.
# CLAUDE_CLI=/Users/you/.local/bin/claude
